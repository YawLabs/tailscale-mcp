{
  "name": "@yawlabs/tailscale-mcp",
  "version": "0.1.4",
  "description": "Tailscale MCP server for managing your tailnet from AI assistants",
  "license": "MIT",
  "author": "YawLabs <contact@yaw.sh>",
  "repository": {
    "type": "git",
